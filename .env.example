# ─── LLM ────────────────────────────────────────────────────────────────────
# Primary model (Claude via Anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: OpenRouter for model switching
OPENROUTER_API_KEY=sk-or-...

# Gemini API Key for validation, optimization, and image/video analysis
GEMINI_API_KEY=

# ─── Execution Sandbox ───────────────────────────────────────────────────────
E2B_API_KEY=e2b_...

# ─── Rate Limiting (Upstash) ─────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...
WAITLIST_SECRET=...

# ─── Auth & Integrations (Nango) ─────────────────────────────────────────────
# Your Nango secret key — never expose this to the browser.
# Found in the Nango dashboard under Environment Settings.
NANGO_SECRET_KEY=...

# Webhook secret — set this in Nango dashboard (Environment Settings → Webhook Secret)
# then uncomment the HMAC verification block in app/api/nango/webhook/route.ts.
NANGO_WEBHOOK_SECRET=...

# ─── Composio ─────────────────────────────────────────────────────────────────
# Get your API key from https://composio.dev
COMPOSIO_API_KEY=ak_...

# Your app's base URL — used to construct OAuth callback URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NOTE: NEXT_PUBLIC_NANGO_PUBLIC_KEY is no longer required.
# Auth is handled via backend session tokens (POST /api/nango/session).
# The public key flow (legacy popup) has been replaced with the Connect UI SDK.

# ─── Database ────────────────────────────────────────────────────────────────
# Neon serverless Postgres connection string
DATABASE_URL=postgresql://user:pass@host.neon.tech/neondb?sslmode=require

# ─── Scheduling ──────────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=...

# ─── App ─────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=your-random-secret-here

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Secret for signing session tokens
JWT_SECRET=your-jwt-secret-here
